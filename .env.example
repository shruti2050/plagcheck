# PlagCheck SaaS — Environment Configuration
# Copy this to .env and customize

# ── Ollama ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Model to use (must be pulled first with: ollama pull <model>)
# Options (free, open-source):
#   mistral       — 7B, fast, great quality        (recommended)
#   llama3        — 8B, excellent quality
#   gemma2        — 9B, Google's model
#   phi3          — 3.8B, very fast, lower quality
#   qwen2         — 7B, multilingual support
OLLAMA_MODEL=mistral

# ── Analysis ─────────────────────────────────────────────────────────────
# Words per analysis chunk (larger = more context, slower)
CHUNK_SIZE=2000

# Maximum document size in words
MAX_WORDS=200000

# ── Database ─────────────────────────────────────────────────────────────
DB_PATH=plagcheck.db

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
